{
    "version": 6,
    "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
    "configurePresets": [
        {
            "name": "native-debug",
            "displayName": "Native Debug",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/native-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "native-release",
            "displayName": "Native Release",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/native-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "wasm",
            "displayName": "WASM (Emscripten)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/wasm",
            "toolchainFile": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        { "name": "native-debug", "configurePreset": "native-debug" },
        { "name": "native-release", "configurePreset": "native-release" },
        { "name": "wasm", "configurePreset": "wasm" }
    ],
    "testPresets": [
        {
            "name": "native-debug",
            "configurePreset": "native-debug",
            "output": { "outputOnFailure": true }
        }
    ]
}
